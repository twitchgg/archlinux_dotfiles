{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "transient_prompt": {
    "template": "❯",
    "foreground": "#5FD700",
    "background": "transparent"
  },
  "console_title_template": "{{ .Folder }}",
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "properties": {
            "postfix": "\n",
            "prefix": "",
            "text": ""
          },
          "type": "text",
          "style": "plain"
        },
        {
          "properties": {
            "windows": "\ue70f"
          },
          "foreground": "#080808",
          "background": "#CCCCCC",
          "type": "os",
          "style": "powerline"
        },
        {
          "properties": {
            "home_icon": "~",
            "prefix": " \uf07c ",
            "style": "full"
          },
          "foreground": "#e4e4e4",
          "powerline_symbol": "\ue0b0",
          "background": "#0037DA",
          "type": "path",
          "style": "powerline"
        },
        {
          "properties": {
            "branch_icon": "\uf126 ",
            "display_stash_count": true,
            "display_status": true,
            "display_upstream_icon": true,
            "display_worktree_count": true,
            "local_changes_color": "#C19C00",
            "status_colors_enabled": true
          },
          "foreground": "#0C0C0C",
          "powerline_symbol": "\ue0b0",
          "background": "#13A10E",
          "type": "git",
          "style": "powerline"
        }
      ]
    },
    {
      "type": "rprompt",
      "segments": [
        {
          "properties": {
            "always_enabled": true,
            "always_numeric": true,
            "color_background": true,
            "display_exit_code": true,
            "error_color": "#C50F1F",
            "error_icon": "<#C19C00>✘ </>",
            "success_icon": "<#13A10E>✔</>"
          },
          "foreground": "#C19C00",
          "powerline_symbol": "\ue0b2",
          "background": "#0C0C0C",
          "type": "exit",
          "style": "powerline",
          "invert_powerline": true
        },
        {
          "properties": {
            "postfix": " \uf252 "
          },
          "foreground": "#0C0C0C",
          "powerline_symbol": "\ue0b2",
          "background": "#C19C00",
          "type": "executiontime",
          "style": "powerline",
          "invert_powerline": true
        },
        {
          "properties": {
            "root_icon": "\uf132"
          },
          "foreground": "#C50F1F",
          "powerline_symbol": "\ue0b2",
          "background": "#0C0C0C",
          "type": "root",
          "style": "powerline",
          "invert_powerline": true
        },
        {
          "properties": {
            "postfix": " \uf017 ",
            "time_format": "15:04:05"
          },
          "foreground": "#0C0C0C",
          "powerline_symbol": "\ue0b2",
          "background": "#CCCCCC",
          "type": "time",
          "style": "powerline",
          "invert_powerline": true
        },
        {
          "properties": {
            "postfix": "",
            "prefix": "",
            "text": ""
          },
          "type": "text",
          "style": "powerline"
        }
      ]
    }
  ],
  "version": 3,
  "final_space": true
}
